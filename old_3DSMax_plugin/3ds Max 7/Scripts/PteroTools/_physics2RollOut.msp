rollout Physics2RollOut "Physics 2" rolledUp:true (
	-- locals
	local CSVData = _CSVData()
	-- init GUI
	include "$scripts\\pteroTools\\_propGroupUI.ms"
		spinner			spnWeight		"Weight:"			range:[0, 65535, 0]	type:#float		FieldWidth:50	offset:[-20,0]	align:#right
		checkbox		cbxCollide		"Collide with PC and NPC"																align:#left
		checkbox		cbxCanMove		"Accept force from PC and NPC"															align:#left
		checkbox		cbxTrash		"Trash - don't collide together"														align:#left
		checkbox		cbxSynchronize	"Synchronize via network"																align:#left
		dropdownlist	drpSound		"Sound:"												width:144		height:7		align:#center 	items:#("ABCDEFGHIJKLMNOPQRSTUVWXYZ123456789012345")
--		spinner			spnDensity	"Density:"			range:[0, 65535, 0]	type:#float		FieldWidth:50	offset:[-20,0]	align:#right
--		spinner			spnInertia	"MoI:"				range:[0, 65535, 0]	type:#float		FieldWidth:50	offset:[-20,0]	align:#right
--		checkbox		cbxDefMoi	"Default Moment of Inertia"																align:#left
--		dropdownlist	drpStatus	"Type:"													width:144		height:7		align:#center 	items:#("ABCDEFGHIJKLMNOPQRSTUVWXYZ123456789012345")

	-- Init RollOut
	fn fnName		= Physics2RollOut
	fn fnLabel		= "Physics 2"
 	fn fnKeyNames	= #( "Phy_weight", "Phy_collide", "Phy_acceptforce", "Phy_trash", "Phy_synchronize", "Phy_sound" )
 	fn fnKeyUI		= #( #( spnWeight ), #( cbxCollide ), #( cbxCanMove ), #( cbxTrash ), #( cbxSynchronize ), #( drpSound ) )
 	fn fnKeyDef		= #( #( 0 ), #( 0 ), #( 0 ), #( 0 ), #( 0 ), #( 0 ) )
	fn fnInitRollOut = (
		fnAppendRollOut (fnName()) (fnLabel())
	)
 	
	-- fnApply()
	fn fnApply obj keyIDX type acqObj = (
		local keys		= _keyTableDef (fnKeyNames()) (fnKeyUI()) (fnKeyDef())
		local keyArray	= _keyDef keys.names[keyIDX] (keys.names[keyIDX] + "=undefined") #("undefined")

		-- SAVE PRESSET
		if type == #save do (
			----
			if keyIDX == 1 then
			(
				keys.values[keyIDX][1] = keys.controls[keyIDX][1].value
			) else if keyIDX < 6 then
			(
				keys.values[keyIDX][1] = if keys.controls[keyIDX][1].checked then 1 else 0
			) else
			(	
				keys.values[keyIDX][1] = CSVData.ids[keys.controls[keyIDX][1].selection]
			)
			----
			fnSetDefs (keys.names[keyIDX] as string) (keys.values[keyIDX] as string)
			return true
		)

		if obj != undefined do (
			-- DELETE
			if type == #delete do (
				fnDeleteProp obj keys.names[keyIDX]
				type = #read
			)
			-- ACQUIRE or READ
			keyArray = fnReadPropEnhanced (if type == #acquire then acqObj else obj) keys.names[keyIDX]
		)
		
		-- UPDATE UI
		if type == #read or type == #load or type == #acquire do (
			-- LOAD PRESSET
			if type == #load do keyArray.values = fnGetDefs keys.names[keyIDX]
			----
			if (keyArray.values[1] == "") or (keyArray.values[1] as string == "undefined") do
				keyArray.values = keys.values[keyIDX]
			if keyIDX == 1 then
			(
				if keyArray.values[1] as float > -0.1 do keys.controls[keyIDX][1].value = keyArray.values[1] as float
			) else if keyIDX < 6 then
			(
				keys.controls[keyIDX][1].checked = if keyArray.values[1] == 1.0 then true else false
			) else
			(
				local z = findItem CSVData.ids keyArray.values[1]
				keys.controls[keyIDX][1].selection = if z > 0 then z else 1
			)
			----
			if type == #read do return true
			if btnAuto.checked do type = #write
		)

		-- WRITE
		if type == #write do (
			keyArray.keyName = keys.names[keyIDX]
			----
			if keyIDX == 1 then
			(
				--if keys.controls[keyIDX][1].value == 0 then type = #delete else 
				keyArray.values[1] = keys.controls[keyIDX][1].value as string
			) else if keyIDX < 6 then
			(
				if keys.controls[keyIDX][1].checked then keyArray.values[1] = "1" else type = #delete
			) else
			(
				if keys.controls[keyIDX][1].selection == 1 then type =#delete else keyArray.values[1] = CSVData.ids[keys.controls[keyIDX][1].selection] as string
			)
			----
			if obj != undefined do
/*				if type == #delete then
					fnDeleteProp obj keys.names[keyIDX]
				else
*/					fnWritePropEnhanced obj keyArray delete:(if type == #delete then true else false)
			return true
		)
	)
	
	-- fnUpdate()
	fn fnUpdate keyIDX:1 type:#none acqObj:undefined inner:true = (
		if btnAuto.checked and type == #none do type = #write

		setWaitCursor()
		
		case selection.count of (
			0:		 fnApply undefined keyIDX type acqObj
--			default: for obj in selection do fnApply obj keyIDX type acqObj
			1:		 fnApply selection[1] keyIDX type acqObj
			default: case type of 
			(
				#multiSame : fnApply selection[1] keyIDX #read acqObj
				#multiDiff : fnApply undefined keyIDX #read acqObj
				default : for obj in selection do fnApply obj keyIDX type acqObj
			)					
		)
			
		if keyIDX == 2 then
		(
			cbxCanMove.enabled = cbxCollide.checked
			if not cbxCollide.checked and type == #write then
			(
				cbxCanMove.checked = false
				fnUpdate keyIDX:3
			)
		) else if keyIDX == 3 then
		(
			cbxSynchronize.enabled = not cbxCanMove.checked
			if cbxCanMove.checked and type == #write then
			(
				cbxSynchronize.checked = true
				fnUpdate keyIDX:5
			)
		)

		setArrowCursor()

		if inner or type == #acquire do _mainRollout.name.fnUtilize (fnName()) info:true
	)

	-- Event Handler
	on spnWeight		entered			do fnUpdate keyIDX:1
	on cbxCollide		changed state	do fnUpdate keyIDX:2
	on cbxCanMove		changed state	do fnUpdate keyIDX:3
	on cbxTrash			changed state	do fnUpdate keyIDX:4
	on cbxSynchronize	changed state	do fnUpdate keyIDX:5
	on drpSound			selected state	do fnUpdate keyIDX:6
	on btnSet			pressed			do for n = 1 to (fnKeyNames()).count do fnUpdate keyIDX:n type:#write
	on btnDef			pressed			do for n = 1 to (fnKeyNames()).count do fnUpdate keyIDX:n type:#load
	on btnSav			pressed			do for n = 1 to (fnKeyNames()).count do fnUpdate keyIDX:n type:#save
	on btnDel			pressed			do for n = 1 to (fnKeyNames()).count do fnUpdate keyIDX:n type:#delete
	on btnAcq			changed state	do fnAcquire (fnName()) keys:(fnKeyNames()).count
	on Physics2RollOut	open			do 
	(
		local CSVDataTmp = _CSVData()
		local enginePath = ""
		local tmp
		
		-- get engine directory
		while enginePath == "" do (
			tmp = fnLoadINI "EnginePath" (fnReturnFilename #ini) "General"
			if tmp == "undefined" or tmp == "" or tmp == ok then fnPteroSettings()
			else enginePath = tmp
		)
		
		-- get and sort CSV data
		CSVData	= fnParseCSV (enginePath + "\ini\phy_sounds.csv")
		CSVDataTmp = fnParseCSV (enginePath + "\ini\phy_sounds.csv")
		-- sort CSV data
		sort CSVData.names
		for n = 1 to CSVData.count do
		(
			tmp = findItem CSVData.names CSVDataTmp.names[n]
			if n > 0 do
				CSVData.ids[tmp] = CSVDataTmp.ids[n]
		)
		-- fill drpSound UI item
		insertItem "- none -" CSVData.names 1
		insertItem 0 CSVData.ids 1
		drpSound.items = CSVData.names

		fnOpenRollOut (fnName()) keys:(fnKeyNames()).count
	)
	on Physics2RollOut	close			do fnCloseRollOut (fnName())
)
