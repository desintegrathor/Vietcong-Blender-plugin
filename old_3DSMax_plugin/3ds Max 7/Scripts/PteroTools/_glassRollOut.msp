-- TODO: nastavovani barvy
-- TODO: nastavovani barvy nemeni zapis do Props, kdyz je sec or ocl
-- TODO: Acquire nefunguje dobre - nemaze stary zapis

rollout GlassRollOut "Glass" rolledUp:true (
	-- init GUI
	include "$scripts\\pteroTools\\_propGroupUI.ms"
	dropdownList	drpType			"Type:"						Width:144		height:6		align:#center
	dropdownList	drpBES			"Broken glass BES:"			Width:144		height:6		align:#center
	checkbox		chkDontRotate	"Don't rotate fragments"	Width:144						align:#left
	checkbox		chkDontMirror	"Don't mirror fragments"	Width:144						align:#left
	group "" (
		label lbl1 "You have to fill Collisions and Physic too!" offset:[0,-6]	Width:144	height:28	align:#center
	)

	-- fnInitRollOut()
	fn fnName		= GlassRollOut
	fn fnLabel		= "Glass"
 	fn fnKeyNames = #( #("glass", "glass_dummy"), #("glass_dont_rotate"), #("glass_dont_mirror"))
 	fn fnKeyUI = #( #(drpBES, drpType), #(chkDontRotate), #(chkDontMirror) )
 	fn fnKeyDef = #( #("", 0), #(0), #(0) )
	fn fnInitRollOut = (
		fnAppendRollOut (fnName()) (fnLabel())
	)

	-- fnPropsKeyIDX
	fn fnPropsKeyIDX obj =
	(
		if obj != undefined then (
			local pteroBuffer = getUserPropBuffer obj
			local keys	= _keyTableDef (fnKeyNames())[1] (fnKeyUI())[1] (fnKeyDef())[1]
			local ret	= 0

			for n = keys.names.count to 1 by -1 do
				if (findString pteroBuffer keys.names[n]) != undefined do (
					ret = n
					exit
				)
			return ret
		) else
			return 0
	)
 
	-- fnApply()
	fn fnApply obj keyIDX type acqObj = (
		local keys		= _keyTableDef (fnKeyNames()) (fnKeyUI()) (fnKeyDef())
		local keyArray	= _keyDef "" "" #("undefined")
		local subKeyIDX = 1
		
		-- FIND KEYIDX
		if keyIDX == 1 do
		(
			subKeyIDX = case type of (
				#read:		fnPropsKeyIDX obj
				#write:		drpType.selection - 1
				#delete:	fnPropsKeyIDX obj
				#acquire:	fnPropsKeyIDX acqObj
				#load:		(fnGetDefs (fnLabel()))[1]
				#save:		drpType.selection - 1
				#none:		return true
			)
			
			if subKeyIDX == undefined do return true

			drpType.selection = if type == #delete then 1 else (subKeyIDX + 1) 
			if type != #acquire do
			(
				if subKeyIDX <= 0 do
				(
					subKeyIDX = 1
					type = #delete
				)
			)
		)
		keyArray = _keyDef keys.names[keyIDX][subKeyIDX] (keys.names[keyIDX][subKeyIDX] + "=undefined") #("undefined")
		
		-- SAVE PRESSET
		if type == #save do (
			----
			if keyIDX == 1 then
			(
				if subKeyIDX == 1 then
					keys.values[keyIDX][subKeyIDX] = keys.controls[keyIDX][subKeyIDX].selected
				else
					keys.values[keyIDX][subKeyIDX] = 1
				fnSetDefs (fnKeyNames())[keyIDX][1] ( #(subKeyIDX, keys.values[keyIDX][subKeyIDX]) as string )
			)
			else
			if keyIDX > 1 then
			(
				if drpType.selection == 2 then
					keys.values[keyIDX][subKeyIDX] = if keys.controls[keyIDX][subKeyIDX].checked then 1 else 0
				else
					keys.values[keyIDX][subKeyIDX] = 0
				fnSetDefs (fnKeyNames())[keyIDX][1] (keys.values[keyIDX][subKeyIDX] as string)
			)
			----
			return true
		)

		if obj != undefined do (
			-- DELETE WRONG ENTRY
			if type == #write or btnAuto.checked and type == #load or btnAuto.checked and type == #acquire do
			(
				if drpType.selection == 2 or drpType.selection == 1 then
					fnDeleteProp obj keys.names[1][2]

				if drpType.selection == 3 or drpType.selection == 1 then
					fnDeleteProp obj keys.names[1][1]
			) 
			-- DELETE
			if type == #delete do
			(
				fnWritePropEnhanced obj keyArray delete:true 
				type = #read
			) 
			-- ACQUIRE or READ
			keyArray = fnReadPropEnhanced (if type == #acquire then acqObj else obj) keys.names[keyIDX][subKeyIDX]
		)

		-- UPDATE UI
		if type == #read or type == #load or type == #acquire do (
			-- LOAD PRESSET
			if type == #load do
			(
				keyArray.values = fnGetDefs keys.names[keyIDX][1]
				if classof keyArray.values != Array then
					keyArray.values = #(keyArray.values)
				else
					deleteItem keyArray.values 1
			)
			----
			if (keyArray.values[1] == "") or (keyArray.values[1] as string == "undefined") do
				keyArray.values = keys.values[keyIDX]
			if keyIDX == 1 then
			(
				if keyArray.values.count == 1 then keyArray.values = #(#(keyArray.values[1], 0))
				keys.controls[keyIDX][1].selection = findItem keys.controls[keyIDX][1].items keyArray.values[1][1]
				if keys.controls[keyIDX][1].selection == 0 then keys.controls[keyIDX][1].selection = 1
			)
			else
			(
				keys.controls[keyIDX][1].checked = if keyArray.values[1] == 1 then true else false
			)
			----
			if type == #read do return true
			if btnAuto.checked do type = #write
		)

		-- WRITE
		if type == #write do (
			keyArray.keyName = keys.names[keyIDX][subKeyIDX]
			----
			if keyIDX == 1 then
			(
				if subKeyIDX == 1 then
					keyArray.values[1] = keys.controls[keyIDX][subKeyIDX].selected
				else
					keyArray.values[1] = "1"
			)
			else
			if keyIDX > 1 then
			(
				if drpType.selection == 2 then
					keyArray.values[1] = if keys.controls[keyIDX][subKeyIDX].checked then "1" else "0"
				else
					keyArray.values[1] = "0"
				if keyArray.values[1] == "0" then type = #delete
			)
			----
			if obj != undefined do
				fnWritePropEnhanced obj keyArray delete:(if type == #delete then true else false)
				
			return true
		)
	)

	-- fnUpdate()
	fn fnUpdate keyIDX:1 type:#none acqObj:undefined inner:true = (
		if btnAuto.checked and type == #none do type = #write

		/*
		if not inner do
			case keyIDX of
			(
				1: ()
				
				default: return true
			)
		*/
		setWaitCursor()

		case selection.count of (
			0:		 fnApply undefined keyIDX type acqObj
			default: for obj in selection do fnApply obj keyIDX type acqObj
		)

		setArrowCursor()

		if inner or type == #acquire do _mainRollout.name.fnUtilize (fnName()) info:true

		if drpType.selection == 2 then
		(
			drpBES.enabled = true
			chkDontRotate.enabled = true
			chkDontMirror.enabled = true
			lbl1.enabled = true
		)
		else
		(
			drpBES.enabled = false
			chkDontRotate.enabled = false
			chkDontMirror.enabled = false
			lbl1.enabled = false
		)
	)

	-- fnFillBESNames()
	fn fnFillBESNames =
	(
		local ret = #()
		local files
		local s_BESPath = fnReturnPath #model
		local s_BasicBES = "glass_rectangle.bes"
		
		-- exit if path doesn't exist
		if s_BESPath == undefined then return #(s_BasicBES)
		
		-- get all BES files in directory
		files = sort (getFiles (s_BESPath + "\\glass\\*.bes"))

		-- append filenames to list		
		for f in files do append ret (filenameFromPath f)
		
		if ret[1] == undefined then
			return #(s_BasicBES)
		else
			return ret
	)
	
	-- fnProcessType
	fn fnProcessType keyIDX =
	(
		case drpType.selection of
		(
			1:	-- delete all
				for n = 1 to (fnKeyNames()).count do fnUpdate keyIDX:n type:#delete
			2:	-- update check boxes
				for n = 2 to (fnKeyNames()).count do fnUpdate keyIDX:n
			3:	-- erase check boxes
				for n = 2 to (fnKeyNames()).count do fnUpdate keyIDX:n type:#delete
		)
		fnUpdate keyIDX:keyIDX
	)
	
	-- Event Handler
	on drpType			selected state	do fnProcessType 1
	on drpBES			selected state	do fnUpdate keyIDX:1
	on chkDontRotate	changed state	do fnUpdate keyIDX:2
	on chkDontMirror	changed state	do fnUpdate keyIDX:3
	on btnAcq			changed state	do fnAcquire (fnName()) keys:((fnKeyNames()).count)
	on btnSet			pressed			do for n = 1 to (fnKeyNames()).count do fnUpdate keyIDX:n type:#write
	on btnDef			pressed			do for n = 1 to (fnKeyNames()).count do fnUpdate keyIDX:n type:#load
	on btnSav			pressed			do for n = 1 to (fnKeyNames()).count do fnUpdate keyIDX:n type:#save
	on btnDel			pressed			do for n = 1 to (fnKeyNames()).count do fnUpdate keyIDX:n type:#delete
	on GlassRollOut	open			do (
		drpType.items = #("- None -") +  (fnKeyNames())[1]
		drpBES.items = fnFillBESNames()
		fnOpenRollOut (fnName())
	)
	on GlassRollOut	close			do fnCloseRollOut (fnName())
)
