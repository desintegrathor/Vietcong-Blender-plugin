rollout SmoothRollOut "Smooth" rolledUp:true (
	-- init GUI
	include "$scripts\\pteroTools\\_propGroupUI.ms"
	spinner		spnAngle	"Angle:"		FieldWidth:40	type:#float		range:[0, 180, 0]	align:#left		offset:[20,0]	across:2
	angle		angAngle	""				diameter:17		dir:#ccw		range:[0,180,0]		align:#right	offset:[-15,0]	degrees:0		StartDegrees:0	color:(color 255 255 0)
	group "Groups" (
		checkbutton	btnGrp01	"1"			width:16	height:16	offset:[-5,0]	align:#left		across:8
		checkbutton	btnGrp02	"2"			width:16	height:16	offset:[-1,0]
		checkbutton	btnGrp03	"3"			width:16	height:16	offset:[1,0]
		checkbutton	btnGrp04	"4"			width:16	height:16	offset:[3,0]
		checkbutton	btnGrp05	"5"			width:16	height:16	offset:[5,0]
		checkbutton	btnGrp06	"6"			width:16	height:16	offset:[7,0]
		checkbutton	btnGrp07	"7"			width:16	height:16	offset:[9,0]
		checkbutton	btnGrp08	"8"			width:16	height:16	offset:[11,0]
		checkbutton	btnGrp09	"9"			width:16	height:16	offset:[-5,-2]	align:#left		across:8
		checkbutton	btnGrp10	"10"		width:16	height:16	offset:[2,-2]
		checkbutton	btnGrp11	"11"		width:16	height:16	offset:[4,-2]
		checkbutton	btnGrp12	"12"		width:16	height:16	offset:[6,-2]
		checkbutton	btnGrp13	"13"		width:16	height:16	offset:[8,-2]
		checkbutton	btnGrp14	"14"		width:16	height:16	offset:[10,-2]
		checkbutton	btnGrp15	"15"		width:16	height:16	offset:[12,-2]
		checkbutton	btnGrp16	"16"		width:16	height:16	offset:[14,-2]
		checkbutton	btnGrp17	"17"		width:16	height:16	offset:[-5,-2]	align:#left		across:8
		checkbutton	btnGrp18	"18"		width:16	height:16	offset:[2,-2]
		checkbutton	btnGrp19	"19"		width:16	height:16	offset:[4,-2]
		checkbutton	btnGrp20	"20"		width:16	height:16	offset:[6,-2]
		checkbutton	btnGrp21	"21"		width:16	height:16	offset:[8,-2]
		checkbutton	btnGrp22	"22"		width:16	height:16	offset:[10,-2]
		checkbutton	btnGrp23	"23"		width:16	height:16	offset:[12,-2]
		checkbutton	btnGrp24	"24"		width:16	height:16	offset:[14,-2]
		checkbutton	btnGrp25	"25"		width:16	height:16	offset:[-5,-2]	align:#left		across:8
		checkbutton	btnGrp26	"26"		width:16	height:16	offset:[2,-2]
		checkbutton	btnGrp27	"27"		width:16	height:16	offset:[4,-2]
		checkbutton	btnGrp28	"28"		width:16	height:16	offset:[6,-2]
		checkbutton	btnGrp29	"29"		width:16	height:16	offset:[8,-2]
		checkbutton	btnGrp30	"30"		width:16	height:16	offset:[10,-2]
		checkbutton	btnGrp31	"31"		width:16	height:16	offset:[12,-2]
		checkbutton	btnGrp32	"32"		width:16	height:16	offset:[14,-2]
		button		btnClrAll	"Clear All"	width:100	height:18					align:#center
	)

	-- Init RollOut
	fn fnName		= SmoothRollOut
	fn fnLabel		= "Smooth"
 	fn fnKeyNames	= #( (fnLabel()) )
 	fn fnKeyUI		= #( #(
								spnAngle, btnGrp01, btnGrp02, btnGrp03, btnGrp04, btnGrp05, btnGrp06, btnGrp07, btnGrp08,
								btnGrp09, btnGrp10, btnGrp11, btnGrp12, btnGrp13, btnGrp14, btnGrp15, btnGrp16, btnGrp17,
								btnGrp18, btnGrp19, btnGrp20, btnGrp21, btnGrp22, btnGrp23, btnGrp24, btnGrp25, btnGrp26,
								btnGrp27, btnGrp28, btnGrp29, btnGrp30, btnGrp31, btnGrp32
						) )
 	fn fnKeyDef		= #( #( 0 ) )
	fn fnInitRollOut = (
		fnAppendRollOut (fnName()) (fnLabel())
	)


	-- fnApply()
	fn fnApply obj keyIDX type acqObj clr = (
		local keys		= _keyTableDef (fnKeyNames()) (fnKeyUI()) (fnKeyDef())
		local keyArray	= _keyDef keys.names[keyIDX] (keys.names[keyIDX] + "=undefined") #("undefined")

		-- SAVE PRESSET
		if type == #save do (
			----
			for n = 1 to 33 do (
				if n == 1 do keys.values[keyIDX][n] = keys.controls[keyIDX][n].value
				if n >= 2 and keys.controls[keyIDX][n].checked then append keys.values[keyIDX] ( n - 1 )
			)
			----
			fnSetDefs (keys.names[keyIDX] as string) (keys.values[keyIDX] as string)
			return true
		)

		---- CLEAR ALL
		if clr do for n = 2 to 33 do keys.controls[keyIDX][n].checked = false

		if obj != undefined do (
			-- DELETE
			if type == #delete do (
				fnDeleteProp obj keys.names[keyIDX]
				type = #read
			)
			-- ACQUIRE or READ
			keyArray = fnReadPropEnhanced (if type == #acquire then acqObj else obj) keys.names[keyIDX]
		)

		-- UPDATE UI
		if type == #read or type == #load or type == #acquire do (
			-- LOAD PRESSET
			if type == #load do keyArray.values = fnGetDefs keys.names[keyIDX]
			----
			for n = 2 to 33 do keys.controls[keyIDX][n].checked = false
			for n = 1 to 33 do (
				if (keyArray.values[1] == "") or (keyArray.values[1] as string == "undefined") do
					keyArray.values = keys.values[keyIDX]
				if n == 1 do keys.controls[keyIDX][n].value = keyArray.values[1] as float
				if n >= 2 and keyArray.values[n] != undefined do
					keys.controls[keyIDX][(keyArray.values[n] as integer) + 1].checked = true
			)
--			angAngle.degrees = spnAngle.value
			----
			if type == #read do return true
			if btnAuto.checked do type = #write
		)

		-- WRITE
		if type == #write do (
			keyArray.keyName = keys.names[keyIDX]
			----
			type = #delete
			if keys.controls[keyIDX][1].value > 0 do (
				keyArray.values = #( keyArray.values[1] )
				for n = 1 to 33 do (
					if n == 1 do keyArray.values[1] = keys.controls[keyIDX][n].value as string
					if n >= 2 do if keys.controls[keyIDX][n].checked do ( append keyArray.values ((n-1) as string); type = #write )
				)
			)
			----
			if obj != undefined do
/*				if type == #delete then
					fnDeleteProp obj keys.names[keyIDX]
				else
*/					fnWritePropEnhanced obj keyArray delete:(if type == #delete then true else false)
			return true
		)
	)

	-- fnUpdate()
	fn fnUpdate keyIDX:1 type:#none acqObj:undefined inner:true clr:false = (
		if btnAuto.checked and type == #none do type = #write

		setWaitCursor()
		
		case selection.count of (
			0:		 fnApply undefined keyIDX type acqObj clr
--			default: for obj in selection do fnApply obj keyIDX type acqObj clr
			1:		 fnApply selection[1] keyIDX type acqObj clr
			default: case type of 
			(
				#multiSame : fnApply selection[1] keyIDX #read acqObj clr
				#multiDiff : fnApply undefined keyIDX #read acqObj clr
				default : for obj in selection do fnApply obj keyIDX type acqObj clr
			)					
		)

		setArrowCursor()

		if inner or type == #acquire do _mainRollout.name.fnUtilize (fnName()) info:true
	)

	-- Event Handler
	on btnGrp01			changed state	do fnUpdate()
	on btnGrp02			changed state	do fnUpdate()
	on btnGrp03			changed state	do fnUpdate()
	on btnGrp04			changed state	do fnUpdate()
	on btnGrp05			changed state	do fnUpdate()
	on btnGrp06			changed state	do fnUpdate()
	on btnGrp07			changed state	do fnUpdate()
	on btnGrp08			changed state	do fnUpdate()
	on btnGrp09			changed state	do fnUpdate()
	on btnGrp10			changed state	do fnUpdate()
	on btnGrp11			changed state	do fnUpdate()
	on btnGrp12			changed state	do fnUpdate()
	on btnGrp13			changed state	do fnUpdate()
	on btnGrp14			changed state	do fnUpdate()
	on btnGrp15			changed state	do fnUpdate()
	on btnGrp16			changed state	do fnUpdate()
	on btnGrp17			changed state	do fnUpdate()
	on btnGrp18			changed state	do fnUpdate()
	on btnGrp19			changed state	do fnUpdate()
	on btnGrp20			changed state	do fnUpdate()
	on btnGrp21			changed state	do fnUpdate()
	on btnGrp22			changed state	do fnUpdate()
	on btnGrp23			changed state	do fnUpdate()
	on btnGrp24			changed state	do fnUpdate()
	on btnGrp25			changed state	do fnUpdate()
	on btnGrp26			changed state	do fnUpdate()
	on btnGrp27			changed state	do fnUpdate()
	on btnGrp28			changed state	do fnUpdate()
	on btnGrp29			changed state	do fnUpdate()
	on btnGrp30			changed state	do fnUpdate()
	on btnGrp31			changed state	do fnUpdate()
	on btnGrp32			changed state	do fnUpdate()
	on angAngle			changed value	do (spnAngle.value = value; fnUpdate())
	on spnAngle			entered			do (angAngle.degrees = spnAngle.value; fnUpdate())
	on btnClrAll		pressed			do fnUpdate clr:true
	on btnSet			pressed			do fnUpdate type:#write
	on btnDef			pressed			do fnUpdate type:#load
	on btnSav			pressed			do fnUpdate type:#save
	on btnDel			pressed			do fnUpdate type:#delete
	on btnAcq			changed state	do fnAcquire (fnName())
	on SmoothRollOut	open			do fnOpenRollOut (fnName())
	on SmoothRollOut	close			do fnCloseRollOut (fnName())
)
